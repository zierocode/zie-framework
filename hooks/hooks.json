{
  "_hook_output_protocol": {
    "TaskCompleted": "exit(2) + stderr message to block; stdout warning for non-blocking notices",
    "SessionStart": "plain text printed to stdout — injected as session context",
    "UserPromptSubmit": "JSON {\"additionalContext\": \"...\"} printed to stdout",
    "PostToolUse": "plain text warnings/status printed to stdout",
    "PreToolUse": "plain text BLOCKED/WARNING printed to stdout; exit(2) to block; OR {\"updatedInput\": {...}, \"permissionDecision\": \"allow\"} to rewrite input",
    "Stop": "JSON {\"decision\": \"block\", \"reason\": \"...\"} to stdout to re-invoke Claude; or no output for side-effect-only hooks",
    "PreCompact": "no output required; side-effects only (snapshot write)",
    "SubagentStart": "JSON {\"additionalContext\": \"...\"} printed to stdout for Explore|Plan agents",
    "PermissionRequest": "JSON {\"decision\": {\"behavior\": \"allow\", \"updatedPermissions\": {...}}} printed to stdout",
    "PostCompact": "JSON {\"additionalContext\": \"...\"} printed to stdout",
    "PostToolUseFailure": "JSON {\"additionalContext\": \"...\"} printed to stdout",
    "Notification": "JSON {\"additionalContext\": \"...\"} printed to stdout to inject context; empty stdout to pass through"
  },
  "hooks": {
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-resume.py\""
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/intent-sdlc.py\""
        }
      ]
    }
  ],
  "ConfigChange": [
    {
      "matcher": "project_settings|user_settings",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/config-drift.py\""
        }
      ]
    }
  ],
  "SubagentStart": [
    {
      "matcher": "Explore|Plan",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/subagent-context.py\""
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/auto-test.py\""
        },
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.py\"",
          "background": true
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.py\"",
          "background": true
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Write|Edit|Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/safety-check.py\""
        }
      ]
    }
  ],
  "PostToolUseFailure": [
    {
      "matcher": "Bash|Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/failure-context.py\""
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-permissions.py\""
        }
      ]
    }
  ],
  "Stop": [
    {
      "_stop_matcher_note": "Stop events do not support matchers — the matcher field is silently ignored by Claude Code. All Stop hooks fire unconditionally on every session stop. Gate logic must live inside each hook (e.g. is_interrupt check, compact_hint_threshold). Investigated 2026-04-04.",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-handler.py\""
        },
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end.py\"",
          "background": true
        }
      ]
    }
  ],
  "TaskCompleted": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/task-completed-gate.py\""
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "_matcher_note": "SubagentStop does not support matchers in Claude Code plugin spec — hook fires on every subagent completion in any project. Project guard (is_dir check) lives inside subagent-stop.py instead. Investigated 2026-04-04.",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop.py\"",
          "background": true
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-compact.py\""
        }
      ]
    }
  ],
  "PostCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-compact.py\""
        }
      ]
    }
  ],
  "StopFailure": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/stopfailure-log.py\""
        }
      ]
    }
  ],
  "Notification": [
    {
      "matcher": "permission_prompt",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/notification-log.py\""
        }
      ]
    }
  ]
  }
}