# Makefile.local — zie-framework project-specific extensions
# Committed: yes (zie-framework is a plugin repo, not a secrets-bearing app)

# ── Local dev ─────────────────────────────────────────────────────────────────
# Plugin loads from marketplace cache (github:zierocode/zie-framework).
# To test unreleased changes locally: claude --plugin-dir . --dangerously-skip-permissions
_start-dev:
	claude --dangerously-skip-permissions

# ── Lint ──────────────────────────────────────────────────────────────────────
lint: lint-bandit ## Lint Python hooks (syntax + SAST)
	python3 -m py_compile hooks/*.py && echo "All hooks compile OK"

lint-bandit: ## Run Bandit SAST on hooks/ (medium severity + confidence)
	python3 -m bandit -r hooks/ -ll -q -c .bandit

# ── Version bumping ───────────────────────────────────────────────────────────
# Updates .claude-plugin/plugin.json to match VERSION
_bump-extra:
	jq --arg v "$(NEW)" '.version = $$v' .claude-plugin/plugin.json \
	  > .claude-plugin/plugin.json.tmp \
	  && mv .claude-plugin/plugin.json.tmp .claude-plugin/plugin.json

# ── Publish ───────────────────────────────────────────────────────────────────
# Plugin is self-contained — marketplace resolves via github:zierocode/zie-framework.
# autoUpdate: true in settings.json picks up new version on session restart.
_publish:
	gh release create v$(NEW) --title "v$(NEW)" --generate-notes || true

# ── Setup ─────────────────────────────────────────────────────────────────────
_setup-extra:
	pip3 install pytest-cov coverage bandit
	python3 -m coverage --version
	python3 -m coverage sitecustomize
