# Makefile.local — zie-framework project-specific extensions
# Committed: yes (zie-framework is a plugin repo, not a secrets-bearing app)

# ── Local dev ─────────────────────────────────────────────────────────────────
local-dev: ## Open Claude with local plugin (bypasses marketplace cache)
	claude --plugin-dir . --dangerously-skip-permissions

_start-dev: local-dev

# ── Lint ──────────────────────────────────────────────────────────────────────
lint: lint-bandit ## Lint Python hooks (syntax + SAST)
	python3 -m py_compile hooks/*.py && echo "All hooks compile OK"

lint-bandit: ## Run Bandit SAST on hooks/ (medium severity + confidence)
	python3 -m bandit -r hooks/ -ll -q -c .bandit

# ── Version bumping ───────────────────────────────────────────────────────────
# Updates .claude-plugin/plugin.json to match VERSION
_bump-extra:
	jq --arg v "$(NEW)" '.version = $$v' .claude-plugin/plugin.json \
	  > .claude-plugin/plugin.json.tmp \
	  && mv .claude-plugin/plugin.json.tmp .claude-plugin/plugin.json

# ── Publish ───────────────────────────────────────────────────────────────────
# Updates zie-framework version + SHA in the zierocode marketplace (zie-memory repo)
_publish:
	@SHA=$$(git rev-parse HEAD) && \
	jq --arg v "$(NEW)" --arg sha "$$SHA" \
	  '(.plugins[] | select(.name=="zie-framework") | .version) = $$v | \
	   (.plugins[] | select(.name=="zie-framework") | .source.sha) = $$sha' \
	  /Users/zie/Code/zie-memory/.claude-plugin/marketplace.json \
	  > /tmp/mkt.tmp && \
	mv /tmp/mkt.tmp /Users/zie/Code/zie-memory/.claude-plugin/marketplace.json && \
	cd /Users/zie/Code/zie-memory && \
	git add .claude-plugin/marketplace.json && \
	git commit -m "chore: bump zie-framework to v$(NEW) in marketplace" && \
	git push origin dev

# ── Setup ─────────────────────────────────────────────────────────────────────
_setup-extra:
	pip3 install pytest-cov coverage bandit
	python3 -m coverage --version
	python3 -m coverage sitecustomize
